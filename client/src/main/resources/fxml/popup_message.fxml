         <children>
            <JFXButton fx:id="cancelButton" focusTraversable="false" maxWidth="1.7976931348623157E308" prefHeight="38.0" prefWidth="160.0" styleClass="button-close" text="Cancel" HBox.hgrow="ALWAYS" />
            <JFXButton fx:id="actionButton" focusTraversable="false" maxWidth="1.7976931348623157E308" prefHeight="38.0" prefWidth="160.0" styleClass="button-action" text="OK" HBox.hgrow="ALWAYS" />
