<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane maxWidth="1.7976931348623157E308" minWidth="60.0" prefHeight="50.0" prefWidth="210.0" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" minWidth="140.0" prefWidth="280.0">
         <children>
            <FontIcon fx:id="menuIcon" iconLiteral="mdi2c-cog-outline" iconSize="27">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" />
               </HBox.margin>
            </FontIcon>
            <Text fx:id="nameText" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="settings-menu-label" text="Setting Name" />
         </children>
      </HBox>
      <JFXButton fx:id="overlayButton" focusTraversable="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text=" " />
   </children>
</StackPane>
