               <VBox.margin>
                  <Insets left="110.0" right="110.0" />
               </VBox.margin>
            </HBox>
            <ProgressBar prefHeight="38.0" prefWidth="400.0" progress="0.2">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </ProgressBar>
            <HBox alignment="BOTTOM_RIGHT" fillHeight="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="45.0" prefWidth="580.0" spacing="300.0" VBox.vgrow="NEVER">
               <children>
                  <Label alignment="BOTTOM_RIGHT" styleClass="splash-version" text="1.0.0" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
   <stylesheets>
      <URL value="@../css/global.css" />
      <URL value="@../css/splash.css" />
   </stylesheets>
   <effect>
      <DropShadow />
   </effect>
