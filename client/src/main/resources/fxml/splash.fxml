<StackPane fx:id="rootContainer" maxHeight="500.0" maxWidth="550.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="550.0" styleClass="window-card" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.haf.client.controllers.SplashController">
