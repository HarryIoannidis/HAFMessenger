<StackPane maxHeight="500.0" maxWidth="600.0" minHeight="500.0" minWidth="600.0" prefHeight="500.0" prefWidth="600.0" styleClass="window-card" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" minHeight="500.0" minWidth="600.0" prefHeight="500.0" prefWidth="600.0" StackPane.alignment="CENTER">
         <children>
             <ImageView fitHeight="218.0" fitWidth="203.0" pickOnBounds="true" preserveRatio="true">
                 <VBox.margin>
                     <Insets top="30.0" />
                 </VBox.margin>
                 <effect>
                     <DropShadow height="16.0" radius="7.5" width="16.0">
                         <color>
                             <Color opacity="0.8" />
                         </color>
                     </DropShadow>
                 </effect>
                 <Image url="@../images/app_logo.png" />
             </ImageView>
            <Label prefWidth="210.0" styleClass="splash-title" text="Hellenic Air Force">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Label>
            <Label contentDisplay="TOP" minHeight="-Infinity" minWidth="-Infinity" prefHeight="33.0" prefWidth="105.0" styleClass="splash-subtitle" text="Messenger" textAlignment="CENTER" />
            <Pane minWidth="600.0" prefHeight="43.0" prefWidth="600.0" />
            <HBox alignment="CENTER" minHeight="35.0" minWidth="400.0" prefHeight="35.0" prefWidth="400.0">
               <children>
                  <Label styleClass="splash-status" text="Connecting to database..." />
