<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>


<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="400.0" minWidth="420.0" prefHeight="700.0" prefWidth="900.0" stylesheets="@../css/global.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.haf.client.controllers.SearchController">

   <!-- Layer 1: the result cards -->
   <FlowPane fx:id="resultsPane" columnHalignment="CENTER" hgap="30.0" vgap="30.0">
      <opaqueInsets>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </opaqueInsets>
      <padding>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </padding>
   </FlowPane>

   <!-- Layer 2: status overlay (visible when no results) -->
   <VBox fx:id="statusBox" alignment="CENTER" mouseTransparent="true">
      <children>
         <Text fx:id="statusText" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="plain-text" text="Search for users by name or registration number.">
            <font>
               <Font size="14.0" />
            </font>
         </Text>
      </children>
   </VBox>

</StackPane>
